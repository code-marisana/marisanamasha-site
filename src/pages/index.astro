---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import Card from "../components/Card.astro";

const projects = (await getCollection("projects"))
  .filter((project) => project.data.featured)
  .slice(0, 3);
const publications = (await getCollection("publications"))
  .sort((a, b) => b.data.year - a.data.year)
  .slice(0, 3);
---
<BaseLayout
  title="Marisana Masha | Academic Portfolio"
  description="Research portfolio in Chemical Engineering, Energy Systems, Hydrogen Production, and Law."
>
  <section class="animate-rise rounded-2xl bg-white p-8 shadow-card">
    <p class="text-sm uppercase tracking-[0.2em] text-steel">Academic Portfolio</p>
    <h1 class="mt-3 text-4xl font-semibold tracking-tight sm:text-5xl">Research at the intersection of engineering and law.</h1>
    <p class="mt-4 max-w-3xl text-lg text-slate-700">
      I develop clean energy systems and legal frameworks that accelerate hydrogen deployment, sustainable process design,
      and equitable infrastructure governance.
    </p>
    <div class="mt-6 flex flex-wrap gap-3">
      <a class="rounded bg-ink px-4 py-2 text-sm font-medium text-white no-underline hover:bg-[#15365f]" href="/cv">View CV</a>
      <a class="rounded border border-slate-300 px-4 py-2 text-sm font-medium no-underline hover:bg-slate-50" href="/contact">Get in Touch</a>
    </div>
  </section>

  <section class="mt-12">
    <div class="mb-4 flex items-end justify-between">
      <h2 class="text-2xl font-semibold tracking-tight">Featured Projects</h2>
      <a href="/projects">View all</a>
    </div>
    <div class="grid gap-4 md:grid-cols-3">
      {projects.map((project) => <Card href={`/projects/${project.slug}`} title={project.data.title} description={project.data.description} meta={project.data.status} />)}
    </div>
  </section>

  <section class="mt-12">
    <div class="mb-4 flex items-end justify-between">
      <h2 class="text-2xl font-semibold tracking-tight">Recent Publications</h2>
      <a href="/publications">View all</a>
    </div>
    <div class="grid gap-4 md:grid-cols-3">
      {
        publications.map((pub) => (
          <article class="rounded-xl border border-slate-200 bg-white p-5 shadow-card">
            <p class="text-xs uppercase tracking-wide text-steel">{pub.data.year} · {pub.data.fields.join(", ")}</p>
            <h3 class="mt-1 text-lg font-semibold tracking-tight">
              <a class="no-underline hover:underline" href={`/publications/${pub.id}`}>{pub.data.title}</a>
            </h3>
            <p class="mt-2 text-sm text-slate-700">{pub.data.eventName ?? pub.data.journal}</p>
            <p class="mt-3 text-sm">
              {pub.data.doi ? (
                <>
                  DOI:{" "}
                  <a href={`https://doi.org/${pub.data.doi}`} target="_blank" rel="noreferrer">
                    {pub.data.doi}
                  </a>
                </>
              ) : pub.data.url ? (
                <>
                  File:{" "}
                  <a href={pub.data.url} target="_blank" rel="noreferrer">
                    Download publication
                  </a>
                </>
              ) : (
                <span class="text-slate-500">No DOI/file link available.</span>
              )}
            </p>
          </article>
        ))
      }
    </div>
  </section>
</BaseLayout>
