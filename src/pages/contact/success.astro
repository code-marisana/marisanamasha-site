---
import BaseLayout from "../../layouts/BaseLayout.astro";
---
<BaseLayout title="Message Sent | Marisana Masha" description="Your message was submitted successfully.">
  <section class="max-w-2xl rounded-2xl bg-white p-8 shadow-card">
    <h1 class="text-3xl font-semibold tracking-tight">Thank you</h1>
    <p class="mt-3 text-slate-700">Your message has been submitted. I will get back to you soon.</p>
    <a class="mt-6 inline-block rounded border border-slate-300 px-4 py-2 text-sm no-underline" href="/">
      Return home
    </a>
  </section>
</BaseLayout>
