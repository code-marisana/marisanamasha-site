---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

export async function getStaticPaths() {
  const projects = await getCollection("projects");
  return projects.map((project) => ({
    params: { slug: project.slug },
    props: { project }
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);
const startYear = project.data.startDate ? project.data.startDate.getFullYear() : null;
const endYear = project.data.endDate ? project.data.endDate.getFullYear() : null;
const timelineLabel = startYear ? `${startYear} - ${endYear ?? "Present"}` : "N/A";
---
<BaseLayout title={`${project.data.title} | Projects`} description={project.data.description}>
  <article class="space-y-6">
    <header class="rounded-2xl border border-slate-200 bg-white p-8 shadow-card">
      <div class="flex flex-wrap items-center gap-2">
        <span class="rounded-full bg-ink/10 px-3 py-1 text-xs font-semibold uppercase tracking-wide text-ink">
          {project.data.status}
        </span>
        {project.data.featured && (
          <span class="rounded-full bg-emerald-100 px-3 py-1 text-xs font-semibold uppercase tracking-wide text-emerald-700">
            Featured
          </span>
        )}
      </div>
      <h1 class="mt-4 text-3xl font-semibold tracking-tight sm:text-4xl">{project.data.title}</h1>
      <p class="mt-3 max-w-3xl text-slate-700">{project.data.description}</p>
    </header>

    <section class="grid gap-4 md:grid-cols-4">
      <div class="rounded-xl border border-slate-200 bg-white p-5 shadow-card">
        <h2 class="text-sm font-semibold uppercase tracking-wide text-steel">Timeline</h2>
        <p class="mt-2 text-sm text-slate-700">
          {timelineLabel}
        </p>
      </div>

      {project.data.role && (
        <div class="rounded-xl border border-slate-200 bg-white p-5 shadow-card">
          <h2 class="text-sm font-semibold uppercase tracking-wide text-steel">Role</h2>
          <p class="mt-2 text-sm text-slate-700">{project.data.role}</p>
        </div>
      )}

      {project.data.institution && (
        <div class="rounded-xl border border-slate-200 bg-white p-5 shadow-card">
          <h2 class="text-sm font-semibold uppercase tracking-wide text-steel">Institution</h2>
          <p class="mt-2 text-sm text-slate-700">{project.data.institution}</p>
        </div>
      )}

      <div class="rounded-xl border border-slate-200 bg-white p-5 shadow-card md:col-span-4">
        <h2 class="text-sm font-semibold uppercase tracking-wide text-steel">Technology</h2>
        <div class="mt-2 flex flex-wrap gap-2">
          {project.data.tech.map((item) => (
            <span class="rounded-full bg-mist px-3 py-1 text-xs font-medium text-slate-700">{item}</span>
          ))}
        </div>
      </div>
    </section>

    {project.data.links.length > 0 && (
      <section class="rounded-xl border border-slate-200 bg-white p-5 shadow-card">
        <h2 class="text-sm font-semibold uppercase tracking-wide text-steel">Project Links</h2>
        <div class="mt-3 flex flex-wrap gap-3">
          {project.data.links.map((link) => (
            <a class="rounded border border-slate-300 px-3 py-1 text-sm no-underline hover:bg-slate-50" href={link.url} target="_blank" rel="noreferrer">
              {link.label}
            </a>
          ))}
        </div>
      </section>
    )}

    <section class="prose-academic rounded-2xl border border-slate-200 bg-white p-8 shadow-card">
      <Content />
    </section>
  </article>
</BaseLayout>
