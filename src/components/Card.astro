---
interface Props {
  title: string;
  description?: string;
  href?: string;
  meta?: string;
}

const { title, description, href, meta } = Astro.props;
const Wrapper = href ? "a" : "article";
---
<Wrapper
  href={href}
  class="block rounded-xl border border-slate-200 bg-white p-5 shadow-card transition hover:-translate-y-0.5 hover:border-slate-300 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-ink"
>
  {meta && <p class="text-xs uppercase tracking-wide text-steel">{meta}</p>}
  <h3 class="mt-1 text-lg font-semibold tracking-tight">{title}</h3>
  {description && <p class="mt-2 text-sm text-slate-700">{description}</p>}
</Wrapper>
